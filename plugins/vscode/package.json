{
  "name": "novel-library-reader",
  "displayName": "小说书库阅读器",
  "description": "在 VS Code 和 Cursor 代码行内阅读本地小说，并与小说书库桌面端同步。",
  "version": "0.4.2",
  "publisher": "novel-library",
  "license": "MIT",
  "engines": { "vscode": ">=1.85.0" },
  "categories": ["Other"],
  "main": "extension.js",
  "activationEvents": ["onStartupFinished", "onView:novelLibrary.reader", "onCommand:novelLibrary.openReader", "onCommand:novelLibrary.selectBook", "onCommand:novelLibrary.selectChapter", "onCommand:novelLibrary.importFile"],
  "contributes": {
    "commands": [
      { "command": "novelLibrary.openReader", "title": "小说书库: 显示或隐藏代码内阅读" },
      { "command": "novelLibrary.selectBook", "title": "小说书库: 选择小说" },
      { "command": "novelLibrary.selectChapter", "title": "小说书库: 选择章节" },
      { "command": "novelLibrary.nextLine", "title": "小说书库: 下一行" },
      { "command": "novelLibrary.previousLine", "title": "小说书库: 上一行" },
      { "command": "novelLibrary.nextChapter", "title": "小说书库: 下一章" },
      { "command": "novelLibrary.previousChapter", "title": "小说书库: 上一章" },
      { "command": "novelLibrary.importFile", "title": "小说书库: 导入当前文件" },
      { "command": "novelLibrary.openDesktop", "title": "小说书库: 打开桌面端" }
    ],
    "keybindings": [
      { "command": "novelLibrary.openReader", "key": "ctrl+alt+n" },
      { "command": "novelLibrary.nextLine", "key": "ctrl+alt+down", "when": "editorTextFocus" },
      { "command": "novelLibrary.previousLine", "key": "ctrl+alt+up", "when": "editorTextFocus" },
      { "command": "novelLibrary.nextChapter", "key": "ctrl+alt+right", "when": "editorTextFocus" },
      { "command": "novelLibrary.previousChapter", "key": "ctrl+alt+left", "when": "editorTextFocus" },
      { "command": "novelLibrary.openDesktop", "key": "ctrl+alt+o" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "novelLibrary", "title": "小说书库", "icon": "media/novel-library.svg" }
      ]
    },
    "views": {
      "novelLibrary": [
        { "id": "novelLibrary.reader", "name": "小说阅读器", "visibility": "visible" }
      ]
    },
    "menus": {
      "editor/context": [
        { "command": "novelLibrary.importFile", "when": "resourceExtname == .txt || resourceExtname == .epub", "group": "navigation@90" }
      ]
    }
  },
  "scripts": { "validate": "node --check extension.js && node --check bridge.js" }
}
