{
  "name": "novel-library-reader",
  "displayName": "小说书库阅读器",
  "description": "在 VS Code 和 Cursor 代码行内阅读本地小说，并与小说书库桌面端同步。",
  "version": "0.4.4",
  "publisher": "novel-library",
  "license": "MIT",
  "engines": { "vscode": ">=1.85.0" },
  "categories": ["Other"],
  "main": "extension.js",
  "activationEvents": ["onStartupFinished", "onView:novelLibrary.reader", "onCommand:novelLibrary.openReader", "onCommand:novelLibrary.selectBook", "onCommand:novelLibrary.selectChapter", "onCommand:novelLibrary.importFile", "onCommand:novelLibrary.toggleDisplayMode"],
  "contributes": {
    "commands": [
      { "command": "novelLibrary.openReader", "title": "小说书库: 显示或隐藏代码内阅读", "icon": "$(eye)" },
      { "command": "novelLibrary.showReader", "title": "显示代码内阅读", "icon": "$(eye)" },
      { "command": "novelLibrary.hideReader", "title": "隐藏代码内阅读", "icon": "$(eye-closed)" },
      { "command": "novelLibrary.selectBook", "title": "小说书库: 选择小说" },
      { "command": "novelLibrary.selectChapter", "title": "小说书库: 选择章节" },
      { "command": "novelLibrary.nextLine", "title": "下一行", "icon": "$(arrow-down)" },
      { "command": "novelLibrary.previousLine", "title": "上一行", "icon": "$(arrow-up)" },
      { "command": "novelLibrary.nextChapter", "title": "下一章", "icon": "$(arrow-right)" },
      { "command": "novelLibrary.previousChapter", "title": "上一章", "icon": "$(arrow-left)" },
      { "command": "novelLibrary.refreshLibrary", "title": "刷新书架", "icon": "$(refresh)" },
      { "command": "novelLibrary.toggleDisplayMode", "title": "切换阅读显示模式", "icon": "$(layout)" },
      { "command": "novelLibrary.importFile", "title": "小说书库: 导入当前文件", "icon": "$(file-add)" },
      { "command": "novelLibrary.openDesktop", "title": "小说书库: 打开桌面端", "icon": "$(open-preview)" }
    ],
    "keybindings": [
      { "command": "novelLibrary.openReader", "key": "ctrl+alt+n" },
      { "command": "novelLibrary.nextLine", "key": "ctrl+alt+down", "when": "editorTextFocus" },
      { "command": "novelLibrary.previousLine", "key": "ctrl+alt+up", "when": "editorTextFocus" },
      { "command": "novelLibrary.nextChapter", "key": "ctrl+alt+right", "when": "editorTextFocus" },
      { "command": "novelLibrary.previousChapter", "key": "ctrl+alt+left", "when": "editorTextFocus" },
      { "command": "novelLibrary.openDesktop", "key": "ctrl+alt+o" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "novelLibrary", "title": "小说书库", "icon": "media/novel-library.svg" }
      ]
    },
    "views": {
      "novelLibrary": [
        { "id": "novelLibrary.reader", "name": "小说阅读器", "visibility": "visible" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "novelLibrary.showReader", "when": "view == novelLibrary.reader && !novelLibrary.readerEnabled", "group": "navigation@1" },
        { "command": "novelLibrary.hideReader", "when": "view == novelLibrary.reader && novelLibrary.readerEnabled", "group": "navigation@1" },
        { "command": "novelLibrary.previousLine", "when": "view == novelLibrary.reader", "group": "navigation@2" },
        { "command": "novelLibrary.nextLine", "when": "view == novelLibrary.reader", "group": "navigation@3" },
        { "command": "novelLibrary.previousChapter", "when": "view == novelLibrary.reader", "group": "navigation@4" },
        { "command": "novelLibrary.nextChapter", "when": "view == novelLibrary.reader", "group": "navigation@5" },
        { "command": "novelLibrary.refreshLibrary", "when": "view == novelLibrary.reader", "group": "navigation@6" },
        { "command": "novelLibrary.toggleDisplayMode", "when": "view == novelLibrary.reader", "group": "navigation@7" },
        { "command": "novelLibrary.importFile", "when": "view == novelLibrary.reader", "group": "2_actions@1" },
        { "command": "novelLibrary.openDesktop", "when": "view == novelLibrary.reader", "group": "2_actions@2" }
      ],
      "editor/context": [
        { "command": "novelLibrary.importFile", "when": "resourceExtname == .txt || resourceExtname == .epub", "group": "navigation@90" }
      ]
    }
  },
  "scripts": { "validate": "node --check extension.js && node --check bridge.js" }
}
